// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id                String   @id
  name              String
  logo              String?
  address           String?
  contactNumber     String?
  email             String?
  websiteUrl        String?
  category          String?
  contactPersonName String?
  billingAddress    String?
  taxId             String?
  createdAt         DateTime @default(now())
  invites           DealerInvite[]
  dealers           Dealer[]
  submissions       StoreSubmission[]
}

model DealerInvite {
  id           String   @id @default(cuid())
  mobileNumber String   @unique
  dealerCode   String
  dealerName   String?
  brand        Brand    @relation(fields: [brandId], references: [id])
  brandId      String
  status       String   @default("invited") // invited, verified, expired
  createdAt    DateTime @default(now())
}

model Dealer {
  id               String   @id @default(cuid())
  userId           String?  @unique
  mobileNumber     String   @unique
  name             String?
  dealerCode       String
  brand            Brand    @relation(fields: [brandId], references: [id])
  brandId      String
  onboardingStatus String   @default("profile_incomplete")
  lastLogin        DateTime @default(now())
  submissions      StoreSubmission[]
}

model StoreSubmission {
  id             String   @id @default(cuid())
  dealer         Dealer   @relation(fields: [dealerId], references: [id])
  dealerId       String
  brand          Brand    @relation(fields: [brandId], references: [id])
  brandId        String
  storeName      String
  category       String
  address        Json     // Stores: line1, locality, city, state, pincode, full
  location       Json     // Stores: lat, lng, accuracy, method
  media          Json     // Stores: Array of {url, type, timestamp}
  status         String   @default("submitted_for_review")
  reviewComments String?
  qualityScore   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminUser {
  id           String @id @default(cuid())
  mobileNumber String @unique
  role         String @default("admin") // admin, reviewer
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
